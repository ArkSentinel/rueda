# ============================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================
# COPIA ESTE ARCHIVO COMO .env Y COMPLETA LOS DATOS

# -------- Base de datos RDS --------
# Ejemplo: database-1.xxxx.us-east-1.rds.amazonaws.com
DB_HOST=tu-endpoint-rds.amazonaws.com
DB_PORT=3306
DB_NAME=galeria
DB_USER=admin
DB_PASSWORD=tu_contraseña_rds

# -------- AWS S3 --------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=tu_access_key_id
AWS_SECRET_ACCESS_KEY=tu_secret_access_key
AWS_BUCKET=nombre-bucket-s3

# -------- Sesión --------
SESSION_SECRET=genera_una_clave_larga_y_segura_aqui

# -------- Usuario Admin --------
ADMIN_USER=admin
ADMIN_PASSWORD=tu_nueva_contraseña